              name: "点击[完成]",
              activityIds: "com.miui.packageInstaller.ui.normalmode.InstallProgressActivity",
              excludeMatches: "[text*=\"安装失败\"]",
              matches: "[text=\"完成\"]",
              excludeSnapshotUrls: "https://i.gkd.li/i/20282424",
            },
