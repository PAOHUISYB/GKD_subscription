          rules: [
            {
              fastQuery: true,
              activityIds: [
                "com.miui.securityscan.MainActivity",
                "com.miui.permcenter.permissions.SystemAppPermissionDialogActivity",
              ],
              matches: [
                "[id=\"com.miui.securitycenter:id/title\"][text=\"获取位置信息\"]",
                "[text=\"不同意\"]",
              ],
            },
          ],
        },
        {
