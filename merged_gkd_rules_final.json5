            },
            {
              name: "点击【反馈】",
              matchRoot: true,
              matches: "[text=\"反馈\"][visibleToUser=true]",
              excludeMatches: [
                "@[text=\"关闭\"] - [text=\"反馈\"]",
                "[text$=\"秒后，继续阅读下一页\"]",
                "@[text=\"反馈\"][visibleToUser=true][2=parent.childCount]",
              ],
            },
            {
              preKeys: 2,
