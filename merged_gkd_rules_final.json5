            },
            {
              activityIds: "com.jd.lib.message.messagecenter",
              matches: "@[clickable=true] + [text^=\"打开系统通知\"]",
            },
            {
              matches: "@ImageView[clickable=true][visibleToUser=true] <n * > [text=\"开启消息通知\"]",
            },
