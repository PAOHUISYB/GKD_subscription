            {
              name: "勾选\"已了解此应用未经安全检测\"",
              activityIds: "com.miui.packageInstaller.NewInstallerPrepareActivity",
              matches: "[id=\"com.miui.packageinstaller:id/install_checked\"][checked=false]",
